            <img src="/assets/images/content/showcase-image.png" alt="" />
          </div>
        </div>
      </section>

      <section class="feature-c reveal" aria-label="Feature highlight">
        <div class="container feature-c__container">
          <h2 class="feature-c__heading">
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nunc
            vulputate libero
          </h2>
          <div class="media-frame feature-c__image">
            <img src="/assets/images/content/banner-wide.png" alt="" />
