      </footer>
    </div>

    <button
      type="button"
      class="back-to-top"
      id="backToTop"
      aria-label="Back to top"
    >
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M12 19V5" />
        <path d="M5 12l7-7 7 7" />
      </svg>
    </button>

    <script src="/assets/js/main.js"></script>
    <script>
      // If someone is already signed in, swap the CTA buttons for
      // Profile / Logout instead of Sign up / Login.
      (function () {
        var currentUser;
        try {
          currentUser = localStorage.getItem("currentUser");
        } catch (e) {}
        if (!currentUser) return;

        document.querySelectorAll("a.btn--signup").forEach(function (btn) {
          btn.textContent = "My Profile";
          btn.href = "/profile";
        });
        document.querySelectorAll("a.btn--login").forEach(function (btn) {
          btn.textContent = "Logout";
          btn.href = "#";
          btn.addEventListener("click", function (e) {
            e.preventDefault();
            try {
              localStorage.removeItem("currentUser");
            } catch (err) {}
            window.location.reload();
          });
        });
      })();
    </script>
  </body>
</html>
