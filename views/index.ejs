<!DOCTYPE html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <title>Smart Antenna Landing Page</title>

    <!--
    FOUC prevention: runs synchronously before the first paint.
    Reads localStorage first; falls back to the OS preference.
    Sets data-theme on <html> before any CSS is parsed so the
    correct token values are used from the very first rendered frame.
  -->
    <script>
      (function () {
        try {
          var stored = localStorage.getItem("theme");
          if (stored === "dark" || stored === "light") {
            document.documentElement.dataset.theme = stored;
          } else if (
            window.matchMedia("(prefers-color-scheme: dark)").matches
          ) {
            document.documentElement.dataset.theme = "dark";
          }
        } catch (e) {}
      })();
    </script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=ADLaM+Display&family=Outfit:wght@400;600&family=Paytone+One&family=Pavanam&display=swap"
      rel="stylesheet"
    />

    <link rel="stylesheet" href="/assets/css/reset.css" />
    <link rel="stylesheet" href="/assets/css/variables.css" />
    <link rel="stylesheet" href="/assets/css/main.css" />
  </head>
  <body>
    <!-- Dark-mode star field (CSS-only twinkle, visible in dark mode only) -->
    <div class="stars" aria-hidden="true">
      <div class="stars__layer stars__layer--1"></div>
      <div class="stars__layer stars__layer--2"></div>
      <div class="stars__layer stars__layer--3"></div>
    </div>

    <!-- Theme toggle — always visible, highest z-index -->
    <button
      type="button"
      class="theme-toggle"
      id="themeToggle"
      aria-label="Switch to dark mode"
      aria-pressed="false"
    >
      <span class="theme-toggle__track" aria-hidden="true">
        <span class="theme-toggle__thumb">
          <!-- Sun icon -->
          <svg
            class="theme-toggle__sun"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="5" />
            <line
              x1="12"
              y1="1"
              x2="12"
              y2="3"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
            />
            <line
              x1="12"
              y1="21"
              x2="12"
              y2="23"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
            />
            <line
              x1="4.22"
              y1="4.22"
              x2="5.64"
              y2="5.64"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
            />
            <line
              x1="18.36"
              y1="18.36"
              x2="19.78"
              y2="19.78"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
            />
            <line
              x1="1"
              y1="12"
              x2="3"
              y2="12"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
            />
            <line
              x1="21"
              y1="12"
              x2="23"
              y2="12"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
            />
            <line
              x1="4.22"
              y1="19.78"
              x2="5.64"
              y2="18.36"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
            />
            <line
              x1="18.36"
              y1="5.64"
              x2="19.78"
              y2="4.22"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
            />
          </svg>
          <!-- Moon icon -->
          <svg
            class="theme-toggle__moon"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
          </svg>
        </span>
      </span>
      <span class="theme-toggle__label">Light</span>
    </button>
    <div class="scroll-progress" id="scrollProgress" aria-hidden="true"></div>

    <div class="sticky-bar" id="stickyBar" aria-hidden="true" inert>
      <div class="container sticky-bar__inner">
        <a href="/signup" class="btn btn--signup btn--sm" tabindex="-1"
          >sign up</a
        >
        <a href="/login" class="btn btn--login btn--sm" tabindex="-1">Login</a>
      </div>
    </div>

    <div class="page">
      <!-- Ambient background decoration, purely visual -->
      <div class="background-decoration" aria-hidden="true">
        <div class="bg-blur bg-blur--hero"></div>
        <div class="bg-blur bg-blur--lower"></div>
        <div class="bg-gradient bg-gradient--hero-right"></div>
        <div class="bg-gradient bg-gradient--hero-left"></div>
        <div class="bg-gradient bg-gradient--features-right"></div>
        <div class="bg-gradient bg-gradient--features-left"></div>
        <div class="bg-gradient bg-gradient--cta-right"></div>
